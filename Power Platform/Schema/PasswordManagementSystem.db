
Project PasswordManagementSystem {

  database_type: "PostgreSQL"
}

//////////////////////////////////////////////////////
// CORE ORGANIZATION STRUCTURE
//////////////////////////////////////////////////////

Table Department {
  Id int [pk]
  Name varchar
  CreatedAt datetime
}

Table Project {
  Id int [pk]
  Name varchar
  DepartmentId int [ref: > Department.Id]
  CreatedAt datetime
}

Table Client {
  Id int [pk]
  Name varchar
  ProjectId int [ref: > Project.Id]
  CreatedAt datetime
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

Table AppUser {
  Id int [pk]
  Name varchar
  Email varchar [unique]
  IsActive boolean
  CreatedAt datetime
}

//////////////////////////////////////////////////////
// CREDENTIAL STORAGE
//////////////////////////////////////////////////////

Table Credential {
  Id int [pk]
  Name varchar
  Type varchar // Server, DB, API, SaaS
  ClientId int [ref: > Client.Id]

  Username varchar
  PasswordEncrypted text

  Url varchar
  IpAddress varchar
  Notes text

  OwnerUserId int [ref: > AppUser.Id]

  ExpiryDate datetime
  IsActive boolean

  CreatedAt datetime
  UpdatedAt datetime
}

//////////////////////////////////////////////////////
// ACCESS CONTROL (POLYMORPHIC MODEL)
//////////////////////////////////////////////////////

Table CredentialAccess {
  Id int [pk]

  UserId int [ref: > AppUser.Id]
  AccessLevel varchar // View, Edit, Owner

  CategoryType varchar // Department, Project, Client, Credential
  CategoryId int

  CreatedAt datetime

  Indexes {
    (CategoryType, CategoryId)
    (UserId)
  }
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

Table CredentialAudit {
  Id int [pk]

  CredentialId int [ref: > Credential.Id]
  UserId int [ref: > AppUser.Id]

  Action varchar // View, Reveal, Edit, Delete

  Timestamp datetime
  IpAddress varchar
}

//////////////////////////////////////////////////////
// PASSWORD HISTORY
//////////////////////////////////////////////////////

Table CredentialHistory {
  Id int [pk]

  CredentialId int [ref: > Credential.Id]

  OldPasswordEncrypted text

  ChangedBy int [ref: > AppUser.Id]
  ChangedAt datetime
}
